{
    "name": "villermen/doctrine-identity-queuer",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Villermen",
            "email": "villermen@gmail.com"
        }
    ],
    "require": {
        "php": ">=8.4",
        "doctrine/orm": "^3.0.0"
    },
    "autoload": {
        "psr-4": {
            "Villermen\\DoctrineIdentityQueuer\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Villermen\\DoctrineIdentityQueuer\\Test\\": "test/"
        }
    },
    "require-dev": {
        "ext-pdo_sqlite": "*",
        "phpunit/phpunit": "^13.0.5",
        "symfony/cache": "^8.0",
        "symfony/var-dumper": "^8.0.6"
    },
    "config": {
        "platform": {
            "php": "8.4.1"
        },
        "sort-packages": true
    }
}
